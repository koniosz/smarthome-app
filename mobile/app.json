{
  "expo": {
    "name": "SHC Manager",
    "slug": "shc-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "shcmanager",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6d28d9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pl.smarthomecenter.shcmanager",
      "infoPlist": {
        "NSCameraUsageDescription": "Aparat służy do fotografowania dokumentów i kosztów",
        "NSPhotoLibraryUsageDescription": "Galeria służy do wyboru zdjęć dokumentów",
        "NSPhotoLibraryAddUsageDescription": "Zapis zdjęć dokumentów",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "7"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6d28d9"
      },
      "package": "pl.smarthomecenter.shcmanager",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikacja potrzebuje dostępu do galerii",
          "cameraPermission": "Aplikacja potrzebuje dostępu do aparatu"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0e1d577c-6a75-432b-871e-6ea21747f8f4"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "koniosz"
  }
}
