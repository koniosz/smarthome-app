generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String   @id
  name            String
  client_name     String   @default("")
  client_contact  String   @default("")
  project_type    String   @default("installation")
  status          String   @default("offer_submitted")
  budget_amount   Float    @default(0)
  area_m2         Float?
  smart_features  Json     @default("[]")
  start_date      String?
  end_date        String?
  description     String   @default("")
  created_at      String
  updated_at      String
  created_by      String?

  cost_items      CostItem[]
  labor_entries   LaborEntry[]
  client_payments ClientPayment[]
  extra_costs     ExtraCost[]
  access_requests AccessRequest[]
  project_members ProjectMember[]
  ai_quotes       AiQuote[]
  cost_audit_log  CostAuditLog[]
  ksef_invoices       KsefInvoice[]
  ksef_allocations    KsefInvoiceAllocation[]
  documents           ProjectDocument[]

  @@map("projects")
}

model CostItem {
  id                  String   @id
  project_id          String
  category            String   @default("materials")
  description         String
  quantity            Float    @default(1)
  unit_price          Float    @default(0)
  total_price         Float    @default(0)
  supplier            String   @default("")
  invoice_number      String   @default("")
  date                String
  created_at          String
  attachment_filename String?
  attachment_original String?
  ksef_allocation_id  String?  @unique   // powiązanie z alokacją KSeF

  project             Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ksef_allocation     KsefInvoiceAllocation? @relation(fields: [ksef_allocation_id], references: [id], onDelete: SetNull)

  @@map("cost_items")
}

model LaborEntry {
  id          String   @id
  project_id  String
  worker_name String
  date        String
  hours       Float    @default(0)
  hourly_rate Float    @default(0)
  description String   @default("")
  created_at  String

  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("labor_entries")
}

model ClientPayment {
  id             String   @id
  project_id     String
  amount         Float    @default(0)
  date           String
  description    String   @default("")
  invoice_number String   @default("")
  payment_type   String   @default("standard")
  created_at     String

  project        Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("client_payments")
}

model Employee {
  id              String  @id
  name            String
  hourly_rate     Float   @default(0)
  employment_type String  @default("employment")
  position        String  @default("")
  email           String  @default("")
  phone           String  @default("")
  address         String  @default("")
  start_date         String?
  end_date           String?
  notes              String  @default("")
  created_at         String
  updated_at         String  @default("")
  medical_exam_date  String?
  bhp_date           String?

  assets      EmployeeAsset[]
  documents   EmployeeDocument[]

  @@map("employees")
}

model EmployeeAsset {
  id                   String  @id
  employee_id          String
  asset_type           String
  name                 String
  serial_no            String  @default("")
  notes                String  @default("")
  assigned_at          String
  created_at           String
  car_inspection_date  String?
  car_insurance_date   String?

  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  @@map("employee_assets")
}

model EmployeeDocument {
  id          String  @id
  employee_id String
  doc_type    String
  name        String
  file_name   String
  mime_type   String  @default("application/octet-stream")
  file_data   String
  expires_at  String?
  notes       String  @default("")
  uploaded_at String

  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  @@map("employee_documents")
}

model User {
  id            String   @id
  email         String   @unique
  display_name  String
  role          String   @default("employee")
  azure_oid     String?  @unique
  password_hash String?
  created_at    String

  project_members ProjectMember[]
  notifications   Notification[]
  access_requests AccessRequest[]

  @@map("users")
}

model ProjectMember {
  project_id String
  user_id    String

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([project_id, user_id])
  @@map("project_members")
}

model ProductCatalog {
  id           String   @id
  sku          String?  @unique
  brand        String?
  manufacturer String?
  category     String?
  name         String
  unit         String   @default("szt.")
  unit_price   Float    @default(0)
  active       Boolean  @default(true)
  description  String?
  created_at   String?
  updated_at   String?
  last_import  String?
  sort_order   Int?

  @@map("product_catalog")
}

model AiQuote {
  id                   String   @id
  project_id           String
  name                 String?
  status               String   @default("draft")
  discount_pct         Float    @default(0)
  labor_cost_pct       Float    @default(100)
  items                Json?
  description          Json?
  rooms_detected       Json?
  notes                String?
  total_net            Float?
  total_after_discount Float?
  labor_cost           Float?
  grand_total          Float?
  floor_plan_filename  String?
  floor_plan_filenames Json?
  floor_plan_original  String?
  floor_plan_originals Json?
  ai_analysis_raw      String?
  refine_history       Json?
  tokens_input         Int?
  tokens_output        Int?
  cost_usd             Float?
  created_at           String
  updated_at           String?
  created_by           String?

  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("ai_quotes")
}

model ExtraCost {
  id              String   @id
  project_id      String
  description     String
  quantity        Float    @default(1)
  unit_price      Float    @default(0)
  total_price     Float    @default(0)
  date            String
  is_out_of_scope Boolean  @default(false)
  status          String   @default("pending")
  notes           String   @default("")
  created_at      String
  updated_at      String
  sent_at         String?
  client_email    String?
  approval_token  String?  // token współdzielony przez pozycje z jednej wysyłki

  project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("extra_costs")
}

model AccessRequest {
  id              String   @id
  project_id      String
  project_name    String
  requester_id    String
  requester_name  String
  requester_email String
  status          String   @default("pending")
  created_at      String
  updated_at      String

  project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  requester       User     @relation(fields: [requester_id], references: [id], onDelete: Cascade)

  @@map("access_requests")
}

model Notification {
  id         String   @id
  user_id    String
  type       String
  message    String
  data       Json?
  read       Boolean  @default(false)
  created_at String

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Wzorce AI — zatwierdzone przez człowieka oferty używane jako few-shot examples
model AiQuoteExample {
  id              String   @id
  title           String                        // np. "Dom 280m² KNX+Satel+Control4"
  project_type    String   @default("residential") // residential / commercial / apartment
  brands          Json     @default("[]")       // ["KNX","Satel","Control4"]
  area_m2         Float?                        // powierzchnia domu w m²
  rooms_count     Int?                          // liczba pomieszczeń
  ai_prompt       String?                       // oryginalny opis/prompt który dostał AI
  ai_items        Json?                         // lista pozycji jaką AI pierwotnie wygenerowało
  final_items     Json                          // finalna lista po poprawkach człowieka
  final_total_net Float?                        // łączna wartość netto
  human_notes     String?                       // co poprawiłeś i dlaczego (opcjonalne)
  approved_by     String?                       // ID usera który zatwierdził
  approved_by_name String?                      // imię dla wyświetlania
  source_quote_id String?                       // ID oryginalnej wyceny AI (AiQuote)
  created_at      String

  @@map("ai_quote_examples")
}

model CostAuditLog {
  id          String   @id
  project_id  String
  action      String
  entity      String?
  entity_id   String?
  description String?
  user_id     String?
  user_name   String?
  created_at  String

  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("cost_audit_log")
}

// ─── KSeF — Krajowy System e-Faktur ──────────────────────────────────────────

model KsefInvoice {
  id               String   @id
  ksef_number      String?  @unique   // Numer referencyjny KSeF (np. 2023...)
  invoice_number   String?            // Numer faktury wystawcy
  seller_name      String?            // Nazwa sprzedawcy
  seller_nip       String?            // NIP sprzedawcy
  net_amount       Float    @default(0)
  vat_amount       Float    @default(0)
  gross_amount     Float    @default(0)
  currency         String   @default("PLN")
  invoice_date     String?            // Data wystawienia
  acquisition_date String?            // Data pobrania z KSeF
  project_id       String?            // null = nieprzypisana
  notes            String?            // notatka admina
  is_shared        Boolean  @default(false)
  raw_data         String?            // surowe dane JSON z KSeF (do debugowania)
  payment_status   String?            // 'paid' | 'unpaid' | 'partial' | null (unknown)
  payment_source   String?            // 'mt940' | 'przelewy24' | 'manual'
  paid_amount      Float?
  paid_at          String?
  payment_due_date String?
  bank_tx_id       String?            // reference to BankTransaction
  created_at       String

  project     Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)
  allocations KsefInvoiceAllocation[]

  @@map("ksef_invoices")
}

model KsefInvoiceAllocation {
  id              String  @id
  invoice_id      String
  project_id      String?
  amount          Float   @default(0)
  notes           String  @default("")
  category        String  @default("materials")
  allocation_type String  @default("project")
  is_paid         Boolean @default(false)
  // ── CFO financial taxonomy ────────────────────────────────────────────────
  cost_category   String  @default("cogs")        // cogs | sales | ga | operations | financial
  subcategory     String  @default("hardware")     // see COST_TAXONOMY
  business_unit   String  @default("shc")          // shc | gatelynk | shared
  created_at      String
  updated_at      String

  invoice   KsefInvoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  project   Project?    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  cost_item CostItem?

  @@map("ksef_invoice_allocations")
}

model BankTransaction {
  id                String  @id
  source            String  // 'mt940' | 'przelewy24'
  transaction_date  String
  amount            Float
  currency          String  @default("PLN")
  description       String  @default("")  // transfer title / opis
  counterparty      String  @default("")  // name of sender/receiver
  counterparty_iban String  @default("")
  reference         String  @default("")  // bank reference number / P24 order ID
  matched_invoice_id String?
  match_confidence  Float?  // 0-1 confidence score
  created_at        String

  @@map("bank_transactions")
}

model KsefSession {
  id            String  @id
  session_token String
  refresh_token String?
  expires_at    String
  last_sync_at  String?
  created_at    String

  @@map("ksef_sessions")
}

// ─── Project Documents ────────────────────────────────────────────────────────
model ProjectDocument {
  id          String  @id
  project_id  String
  doc_type    String  @default("offer")  // offer, contract, annex, other
  name        String
  file_name   String
  mime_type   String  @default("application/octet-stream")
  file_data   String
  notes       String  @default("")
  uploaded_at String
  uploaded_by String  @default("")

  project     Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  @@map("project_documents")
}

// ─── SMTP / Email configuration ───────────────────────────────────────────────
model SmtpSettings {
  id         String @id @default("default")
  host       String @default("")
  port       Int    @default(587)
  user       String @default("")
  pass       String @default("")
  from_email String @default("")
  from_name  String @default("")
  updated_at String @default("")

  @@map("smtp_settings")
}
