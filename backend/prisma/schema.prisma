generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String   @id
  name            String
  client_name     String   @default("")
  client_contact  String   @default("")
  project_type    String   @default("installation")
  status          String   @default("offer_submitted")
  budget_amount   Float    @default(0)
  area_m2         Float?
  smart_features  Json     @default("[]")
  start_date      String?
  end_date        String?
  description     String   @default("")
  created_at      String
  updated_at      String
  created_by      String?

  cost_items      CostItem[]
  labor_entries   LaborEntry[]
  client_payments ClientPayment[]
  extra_costs     ExtraCost[]
  access_requests AccessRequest[]
  project_members ProjectMember[]
  ai_quotes       AiQuote[]
  cost_audit_log  CostAuditLog[]

  @@map("projects")
}

model CostItem {
  id                  String   @id
  project_id          String
  category            String   @default("materials")
  description         String
  quantity            Float    @default(1)
  unit_price          Float    @default(0)
  total_price         Float    @default(0)
  supplier            String   @default("")
  invoice_number      String   @default("")
  date                String
  created_at          String
  attachment_filename String?
  attachment_original String?

  project             Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("cost_items")
}

model LaborEntry {
  id          String   @id
  project_id  String
  worker_name String
  date        String
  hours       Float    @default(0)
  hourly_rate Float    @default(0)
  description String   @default("")
  created_at  String

  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("labor_entries")
}

model ClientPayment {
  id             String   @id
  project_id     String
  amount         Float    @default(0)
  date           String
  description    String   @default("")
  invoice_number String   @default("")
  payment_type   String   @default("standard")
  created_at     String

  project        Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("client_payments")
}

model Employee {
  id          String   @id
  name        String
  hourly_rate Float    @default(0)
  created_at  String

  @@map("employees")
}

model User {
  id            String   @id
  email         String   @unique
  display_name  String
  role          String   @default("employee")
  azure_oid     String?  @unique
  password_hash String?
  created_at    String

  project_members ProjectMember[]
  notifications   Notification[]
  access_requests AccessRequest[]

  @@map("users")
}

model ProjectMember {
  project_id String
  user_id    String

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([project_id, user_id])
  @@map("project_members")
}

model ProductCatalog {
  id           String   @id
  sku          String?  @unique
  brand        String?
  manufacturer String?
  category     String?
  name         String
  unit         String   @default("szt.")
  unit_price   Float    @default(0)
  active       Boolean  @default(true)

  @@map("product_catalog")
}

model AiQuote {
  id           String   @id
  project_id   String
  name         String?
  status       String   @default("draft")
  discount_pct Float    @default(0)
  items        Json?
  description  Json?
  created_at   String

  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("ai_quotes")
}

model ExtraCost {
  id              String   @id
  project_id      String
  description     String
  quantity        Float    @default(1)
  unit_price      Float    @default(0)
  total_price     Float    @default(0)
  date            String
  is_out_of_scope Boolean  @default(false)
  status          String   @default("pending")
  notes           String   @default("")
  created_at      String
  updated_at      String
  sent_at         String?

  project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("extra_costs")
}

model AccessRequest {
  id              String   @id
  project_id      String
  project_name    String
  requester_id    String
  requester_name  String
  requester_email String
  status          String   @default("pending")
  created_at      String
  updated_at      String

  project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  requester       User     @relation(fields: [requester_id], references: [id], onDelete: Cascade)

  @@map("access_requests")
}

model Notification {
  id         String   @id
  user_id    String
  type       String
  message    String
  data       Json?
  read       Boolean  @default(false)
  created_at String

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model CostAuditLog {
  id          String   @id
  project_id  String
  action      String
  entity      String?
  entity_id   String?
  description String?
  user_id     String?
  user_name   String?
  created_at  String

  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("cost_audit_log")
}
